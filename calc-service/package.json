{
  "name": "pokescouter-calc-service",
  "version": "1.0.0",
  "description": "PokeScouter damage calculation microservice using @smogon/calc",
  "type": "module",
  "scripts": {
    "postinstall": "node ./scripts/ensure-showdown-built.mjs && node ./scripts/ensure-smogon-calc-champions.mjs",
    "build:snapshot": "node ./scripts/build-showdown-snapshot.mjs",
    "build:threat-mix": "node ./scripts/build-meta-threat-mix.mjs",
    "dev": "node ./scripts/ensure-showdown-built.mjs && node ./scripts/ensure-smogon-calc-champions.mjs && tsx watch src/index.ts",
    "build": "node ./scripts/ensure-showdown-built.mjs && node ./scripts/ensure-smogon-calc-champions.mjs && tsc",
    "start": "node dist/index.js",
    "test": "node ./scripts/ensure-showdown-built.mjs && node ./scripts/ensure-smogon-calc-champions.mjs && vitest run"
  },
  "dependencies": {
    "@smogon/calc": "^0.11.0",
    "express": "^5.1.0",
    "pokemon-showdown": "github:smogon/pokemon-showdown#00d8fc0afd3c589043cff60878989b2c892f05f7"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
